# Optional: override API keys at the system level so you don't
# have to paste them into the UI every time.
# Copy this file to .env and fill in the values you need.

# Generic key — used by firecrawl, browserless, scraperapi, apify
# (can be overridden per-agent inside the ApiKey config field)
AGENT_API_KEY=

# Per-service keys (used if set, fall back to AGENT_API_KEY otherwise)
OPENAI_API_KEY=
FIRECRAWL_API_KEY=
APIFY_API_KEY=
SCRAPERAPI_KEY=
BROWSERLESS_TOKEN=
